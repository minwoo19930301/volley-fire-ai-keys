{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "volley-fire-ai-keys",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-05",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "volley-fire-ai-keys",
      "database_id": "replace-with-cloudflare-d1-database-id"
    }
  ]
}
